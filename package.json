{
  "name": "promobot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "browser:lane:bridge": "tsx src/server/cli/browserLaneBridge.ts",
    "browser:lane:local": "tsx src/server/cli/browserLaneLocalRunner.ts",
    "browser:lane:reconcile": "tsx src/server/cli/browserLaneReconcile.ts",
    "browser:lane:submit": "tsx src/server/cli/browserLaneSubmit.ts",
    "browser:handoff:complete": "tsx src/server/cli/browserHandoffComplete.ts",
    "inbox:reply:handoff:complete": "tsx src/server/cli/inboxReplyHandoffComplete.ts",
    "browser:artifacts:archive": "tsx src/server/cli/archiveBrowserArtifacts.ts",
    "runtime:backup": "tsx src/server/cli/runtimeBackup.ts",
    "runtime:restore": "tsx src/server/cli/runtimeRestore.ts",
    "release:bundle": "tsx src/server/cli/releaseBundle.ts",
    "release:verify": "tsx src/server/cli/releaseVerify.ts",
    "release:local": "bash ops/release-promobot.sh",
    "release:deploy": "bash ops/deploy-release.sh",
    "verify:release": "bash ops/verify-release.sh",
    "verify:downloaded-release": "bash ops/verify-downloaded-release.sh",
    "deploy:local": "bash ops/deploy-promobot.sh",
    "rollback:local": "bash ops/rollback-promobot.sh",
    "smoke:server": "tsx src/server/cli/deploymentSmoke.ts",
    "preflight:prod": "tsx src/server/cli/preflightPromobot.ts",
    "preflight:local": "bash ops/preflight-promobot.sh",
    "dev": "vite",
    "dev:server": "tsx watch src/server/index.ts",
    "build": "rm -rf dist && tsc -p tsconfig.json && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/server/index.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "express": "^5.1.0",
    "pm2": "^6.0.10",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.0"
  }
}
