# Server
PORT=3001
# Comma-separated exact IPs, CIDR subnets, or *.
# The middleware also normalizes ::ffff:1.2.3.4 to 1.2.3.4.
# Defaults to * so a fresh checkout or release bundle is reachable immediately.
# Tighten this before exposing the app to untrusted networks.
ALLOWED_IPS=*
# Parsed at boot. In production, the server refuses to start if this is left as the default value.
ADMIN_PASSWORD=change-me

# Dev proxy
# Optional. Vite `pnpm dev` will proxy `/api` to this origin. Defaults to http://127.0.0.1:3001.
PROMOBOT_DEV_API_ORIGIN=http://127.0.0.1:3001

# Storage
# Optional. Defaults to <cwd>/data/promobot.sqlite. With pm2.config.js, <cwd> is the repo root.
PROMOBOT_DB_PATH=./data/promobot.sqlite

# AI generation
# Optional for server boot. Required for AI-backed draft generation and inbox reply suggestions.
# Use an OpenAI-compatible API base URL, for example https://api.openai.com/v1
AI_BASE_URL=https://your-openai-compatible-endpoint.example/v1
AI_API_KEY=your-api-key
# Optional. Defaults to gpt-4o-mini when unset.
AI_MODEL=gpt-4o-mini

# Blog publishing
# Optional. Blog publish driver. Supports file | wordpress | ghost. Defaults to file.
BLOG_PUBLISH_DRIVER=file
# Optional. Local file publish output directory. Only used when BLOG_PUBLISH_DRIVER=file. Defaults to <cwd>/data/blog-posts.
BLOG_PUBLISH_OUTPUT_DIR=./data/blog-posts
# Optional. Required together when BLOG_PUBLISH_DRIVER=wordpress.
BLOG_WORDPRESS_SITE_URL=https://cms.example.com
BLOG_WORDPRESS_USERNAME=editor
BLOG_WORDPRESS_APP_PASSWORD=app-password
# Optional. Required together when BLOG_PUBLISH_DRIVER=ghost.
# BLOG_GHOST_ADMIN_URL can be set with or without the /ghost suffix.
# BLOG_GHOST_ADMIN_API_KEY must use the Ghost Admin API key format: <id>:<secret hex>.
BLOG_GHOST_ADMIN_URL=https://ghost.example.com
BLOG_GHOST_ADMIN_API_KEY=0123456789abcdef:0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Browser handoff artifacts
# Optional. Manual browser handoff artifact output directory. Defaults to the repo / deployment root.
BROWSER_HANDOFF_OUTPUT_DIR=.
# Optional. Opt in to the built-in local browser lane fallback for session_request dispatches
# when no explicit browser lane command is configured. This only reuses managed storage state
# and existing importer/submitter flows; it is not full browser automation.
PROMOBOT_BROWSER_LOCAL_AUTORUN=false
# Optional. Override the fallback command used when PROMOBOT_BROWSER_LOCAL_AUTORUN is enabled.
PROMOBOT_BROWSER_LOCAL_RUNNER_COMMAND=pnpm browser:lane:local

# X publishing
# Optional. Either token enables API publishing mode for X; otherwise X publish attempts fail explicitly.
X_ACCESS_TOKEN=
X_BEARER_TOKEN=

# Reddit publishing
# Optional. Real Reddit API publishing requires CLIENT_ID / CLIENT_SECRET / USERNAME / PASSWORD together.
# USER_AGENT is optional. Defaults to promobot/0.1 when unset.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=promobot/0.1
